{
  "name": "@oktopeak/mycase-mcp",
  "version": "1.0.2",
  "mcpName": "io.github.oktopeak/mycase-mcp",
  "description": "Open-source Model Context Protocol (MCP) server that connects Claude to MyCase legal practice management. 15 tools covering cases, contacts, documents, tasks, calendar, calls, time entries, and billing. Built for law firms with AES-256 encrypted OAuth token storage. Built by Oktopeak.",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "mycase-mcp": "./build/index.js"
  },
  "files": [
    "build",
    ".env.example",
    "server.json",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc && chmod 755 build/index.js",
    "start": "node build/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "mcp",
    "model-context-protocol",
    "claude",
    "anthropic",
    "mycase",
    "legal-tech",
    "law-firm",
    "legal-ai",
    "legal-automation",
    "practice-management",
    "oauth"
  ],
  "author": "Oktopeak <office@oktopeak.com> (https://oktopeak.com)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/oktopeak/mycase-mcp.git"
  },
  "homepage": "https://github.com/oktopeak/mycase-mcp#readme",
  "bugs": {
    "url": "https://github.com/oktopeak/mycase-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.6.1",
    "open": "^11.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
