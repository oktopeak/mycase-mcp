{
  "name": "@oktopeak/mycase-mcp",
  "version": "1.0.0",
  "description": "Open-source MCP server connecting Claude to MyCase practice management. Built by Oktopeak.",
  "type": "module",
  "main": "build/index.js",
  "bin": {
    "mycase-mcp": "./build/index.js"
  },
  "files": [
    "build",
    ".env.example",
    "server.json"
  ],
  "scripts": {
    "build": "tsc",
    "start": "node build/index.js",
    "inspect": "npx @modelcontextprotocol/inspector node build/index.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "prepublishOnly": "npm test && npm run build"
  },
  "keywords": [
    "mcp",
    "mycase",
    "legal",
    "claude",
    "law",
    "practice-management"
  ],
  "author": "Oktopeak",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/oktopeak/mycase-mcp.git"
  },
  "homepage": "https://github.com/oktopeak/mycase-mcp#readme",
  "bugs": {
    "url": "https://github.com/oktopeak/mycase-mcp/issues"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.29.0",
    "dotenv": "^16.6.1",
    "open": "^11.0.0",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.5.0",
    "vitest": "^2.1.9"
  },
  "engines": {
    "node": ">=18"
  }
}
