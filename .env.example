# MyCase OAuth credentials — obtain from MyCase developer settings
MYCASE_CLIENT_ID=
MYCASE_CLIENT_SECRET=

# AES-256-GCM encryption key for token storage
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# OAuth callback port (default: 5678)
MYCASE_REDIRECT_PORT=5678

# MyCase OAuth endpoints
# Confirm exact URLs from https://mycaseapi.stoplight.io on Day 1
MYCASE_AUTH_URL=https://auth.mycase.com/oauth/authorize
MYCASE_TOKEN_URL=https://auth.mycase.com/oauth/token

# MyCase API base URL
MYCASE_API_BASE=https://api.mycase.com/api/v1
