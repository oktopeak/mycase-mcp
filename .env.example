# MyCase OAuth credentials — obtain from MyCase developer settings
MYCASE_CLIENT_ID=
MYCASE_CLIENT_SECRET=

# AES-256-GCM encryption key for token storage
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
ENCRYPTION_KEY=

# OAuth callback port (default: 5678)
MYCASE_REDIRECT_PORT=5678

# MyCase OAuth endpoints
MYCASE_AUTH_URL=https://auth.mycase.com/login_sessions/new
MYCASE_TOKEN_URL=https://auth.mycase.com/tokens

# MyCase API base URL
MYCASE_API_BASE=https://external-integrations.mycase.com/v1
